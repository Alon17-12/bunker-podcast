# =========================================
# Bunker Podcast — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it contains secrets.
# =========================================

# --- Supabase ---
# Get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # server-only — never expose to client
SUPABASE_PROJECT_ID=xxxxx                  # for `npm run db:types`

# --- Bunny Stream ---
# Get from https://dash.bunny.net/stream
BUNNY_LIBRARY_ID=12345
BUNNY_API_KEY=xxx
BUNNY_SECURITY_KEY=xxx                     # for signed URLs
BUNNY_CDN_HOSTNAME=vz-xxx.b-cdn.net

# --- Make.com Webhooks ---
# Create scenarios at https://www.make.com and paste webhook URLs here
MAKE_WEBHOOK_EPISODE_READY=https://hook.eu1.make.com/xxx
MAKE_WEBHOOK_CLIENT_FEEDBACK=https://hook.eu1.make.com/xxx
MAKE_WEBHOOK_REELS_SELECTED=https://hook.eu1.make.com/xxx

# --- Admin notifications ---
ADMIN_EMAIL=alon@bunker.co.il
ADMIN_WHATSAPP=9725XXXXXXXX

# --- App config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000  # change to prod URL when deploying
NEXT_PUBLIC_SHARE_TOKEN_TTL_DAYS=30
